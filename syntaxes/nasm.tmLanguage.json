{
  "scopeName": "source.nasm",
  "name": "NASM",
  "fileTypes": ["asm", "nasm", "s"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#preprocessor" },
    { "include": "#labels" },
    { "include": "#directives" },
    { "include": "#instructions" },
    { "include": "#registers" },
    { "include": "#sizeSpecifiers" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#brackets" },
    { "include": "#separators" }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.semicolon.nasm",
      "match": ";.*$"
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.nasm",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.nasm",
              "match": "''"
            }
          ]
        },
        {
          "name": "string.quoted.double.nasm",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.nasm",
              "match": "\"\""
            }
          ]
        }
      ]
    },
    "preprocessor": {
      "patterns": [
        {
          "name": "keyword.preprocessor.nasm",
          "match": "^\\s*(%define|%xdefine|%ixdefine|%undef|%assign|%iassign|%strlen|%strcat|%substr|%macro|%endmacro|%imacro|%ifdef|%ifndef|%ifidn|%ifnidn|%ifidni|%ifnidni|%ifid|%ifnid|%ifnum|%ifnnum|%ifstr|%ifnstr|%iftoken|%ifntoken|%ifctx|%ifnctx|%elifdef|%elifndef|%elifidn|%elifnidn|%elifidni|%elifnidni|%elifid|%elifnid|%elifnum|%elifnnum|%elifstr|%elifnstr|%eliftoken|%elifntoken|%elifctx|%elifnctx|%else|%endif|%include|%push|%pop|%repl|%error|%warning|%fatal|%line|%pathsearch|%depend|%use|%arg|%stacksize|%local|%endrep|%rep|%exitrep)\\b"
        },
        {
          "name": "entity.name.label.nasm",
          "match": "%%[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "name": "keyword.operator.nasm",
          "match": "%+%|%"
        }
      ]
    },
    "labels": {
      "patterns": [
        {
          "name": "entity.name.label.nasm",
          "match": "^\\s*([a-zA-Z_?.@][a-zA-Z0-9_$.?#@]*)\\s*(?=:)"
        },
        {
          "name": "entity.name.label.nasm",
          "match": "^\\s*(\\.\\.@|[a-zA-Z_?.@][a-zA-Z0-9_$.?#@]*\\.[a-zA-Z0-9_$.?#@]+)\\s*(?=:)"
        },
        {
          "name": "entity.name.label.nasm",
          "match": "^\\s*(@@)\\s*(?=:)"
        },
        {
          "name": "entity.name.label.nasm",
          "match": "@[bf](?![a-zA-Z0-9_])"
        }
      ]
    },
    "directives": {
      "name": "keyword.directive.nasm",
      "match": "\\b(section|segment|global|static|extern|common|export|import|default|bits|cpu|org|align|alignb|incbin|struc|endstruc|istruc|at|iend|macro|endmacro|dw|dw|dd|dd|dq|dq|dt|do|dy|db|resb|resw|resd|resq|rest|resd|resy|resb|equ|times|absolute|extern|global|common|cpu|default|family)\\b"
    },
    "instructions": {
      "patterns": [
        {
          "name": "support.function.nasm",
          "match": "(?<![a-zA-Z0-9_.$])AAA|AAD|AAM|AAS|ADC|ADD|AND|ARPL|BOUND|BSF|BSR|BSWAP|BT|BTC|BTR|BTS|CALL|CBW|CDQ|CDQE|CLC|CLD|CLI|CLTS|CMC|CMP|CMPSB|CMPSD|CMPSQ|CMPSW|CMPXCHG|CMPXCHG486|CMPXCHG8B|CMPXCHG16B|CPUID|CQO|CWD|CWDE|DAA|DAS|DEC|DIV|ENTER|FABS|FADD|FADDP|FIADD|FBLD|FBSTP|FCHS|FCLEX|FCMOVB|FCMOVBE|FCMOVE|FCMOVNB|FCMOVNBE|FCMOVNE|FCMOVNU|FCMOVU|FCOM|FCOMI|FCOMIP|FCOMP|FCOMPP|FCOS|FDECSTP|FDISI|FDIV|FDIVP|FDIVR|FDIVRP|FENI|FFREE|FFREEP|FIADD|FICOM|FICOMP|FIDIV|FIDIVR|FILD|FIMUL|FINCSTP|FINIT|FIST|FISTP|FISTTP|FLD|FLD1|FLDCW|FLDENV|FLDL2E|FLDL2T|FLDLG2|FLDLN2|FLDPI|FLDZ|FMUL|FMULP|FNCLEX|FNDISI|FNENI|FNINIT|FNOP|FNSAVE|FNSTCW|FNSTENV|FNSTSW|FPATAN|FPREM|FPREM1|FPTAN|FRNDINT|FRSTOR|FSAVE|FSCALE|FSETPM|FSIN|FSINCOS|FSQRT|FST|FSTCW|FSTENV|FSTP|FSTSW|FSUB|FSUBP|FSUBR|FSUBRP|FTST|FUCOM|FUCOMI|FUCOMIP|FUCOMP|FUCOMPP|FWAIT|FXAM|FXCH|FXRSTOR|FXSAVE|FXTRACT|FYL2X|FYL2XP1|HLT|IBTS|IDIV|IMUL|IN|INC|INSB|INSD|INSW|INT|INTO|INVD|INVLPG|INVPCID|IRET|IRETD|IRETQ|IRETW|JA|JAE|JB|JBE|JC|JCXZ|JECXZ|JRCXZ|JE|JG|JGE|JL|JLE|JMP|JNA|JNAE|JNB|JNBE|JNC|JNE|JNG|JNGE|JNL|JNLE|JNO|JNP|JNS|JNZ|JO|JP|JPE|JPO|JS|JZ|LAHF|LAR|LDS|LEA|LEAVE|LES|LFENCE|LFS|LGDT|LGS|LIDT|LLDT|LMSW|LOADALL|LOADALL286|LODSB|LODSD|LODSQ|LODSW|LOOP|LOOPE|LOOPNE|LOOPNZ|LOOPZ|LSL|LSS|LTR|MFENCE|MOV|MOVD|MOVQ|MOVSB|MOVSD|MOVSQ|MOVSW|MOVSX|MOVSXD|MOVZX|MUL|MWAIT|NEG|NOP|NOT|OR|OUT|OUTSB|OUTSD|OUTSW|PACKSSDW|PACKSSWB|PACKUSWB|PADDB|PADDD|PADDSB|PADDSW|PADDUSB|PADDUSW|PADDW|PAND|PANDN|PAVGB|PAVGW|PCMPEQB|PCMPEQD|PCMPEQW|PCMPGTB|PCMPGTD|PCMPGTW|PEXTRW|PF2ID|PF2IW|PFACC|PFADD|PFCMPEQ|PFCMPGE|PFCMPGT|PFMAX|PFMIN|PFMUL|PFRCP|PFRCPIT1|PFRCPIT2|PFRSQIT1|PFRSQRT|PFSUB|PFSUBR|PINSRW|PMADDWD|PMAXSW|PMAXUB|PMINSW|PMINUB|PMOVMSKB|PMULHRW|PMULHUW|PMULHW|PMULLW|POP|POPA|POPAD|POPAW|POPF|POPFD|POPFQ|POPFW|POR|PREFETCH|PREFETCHW|PSADBW|PSHUFW|PSLLD|PSLLQ|PSLLW|PSRAD|PSRAW|PSRLD|PSRLQ|PSRLW|PSUBB|PSUBD|PSUBSB|PSUBSW|PSUBUSB|PSUBUSW|PSUBW|PUNPCKHBW|PUNPCKHDQ|PUNPCKHWD|PUNPCKLBW|PUNPCKLDQ|PUNPCKLWD|PUSH|PUSHA|PUSHAD|PUSHAW|PUSHF|PUS