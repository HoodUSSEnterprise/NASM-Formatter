UB213SD|VFMSUB231SD|VFMADDSUB132PS|VFMADDSUB213PS|VFMADDSUB231PS|VFMADDSUB132PD|VFMADDSUB213PD|VFMADDSUB231PD|VFMSUBADD132PS|VFMSUBADD213PS|VFMSUBADD231PS|VFMSUBADD132PD|VFMSUBADD213PD|VFMSUBADD231PD|VCMPSS|VCMPSD|VCMPPS|VCMPPD|VCOMISS|VCOMISD|VUCOMISS|VUCOMISD|VMOVMSKPS|VMOVMSKPD|VSQRTSS|VSQRTSD|VSQRTPS|VSQRTPD|VMAXSS|VMAXSD|VMAXPS|VMAXPD|VMINSS|VMINSB|VMINPS|VMINPD|VBROADCASTSS|VBROADCASTSD|VBROADCASTF128|VINSERTF128|VEXTRACTF128|VPERMILPS|VPERMILPD|VPERM2F128|VMASKMOVPS|VMASKMOVPD|VGATHERDPD|VGATHERQPD|VGATHERDPS|VGATHERQPS|VPGATHERDD|VPGATHERDQ|VPGATHERQD|VPGATHERQQ|VPBROADCASTB|VPBROADCASTW|VPBROADCASTD|VPBROADCASTQ|VPABSB|VPABSW|VPABSD|VPABSQ|VPALIGNR|PABSQ|VPHADDD|VPHADDSW|VPHADDW|VPHSUBD|VPHSUBSW|VPHSUBW|VPMADDUBSW|VPMULHRSW|VPSHUFB|VPSIGNB|VPSIGNW|VPSIGND|VBLENDPS|VBLENDPD|VBLENDVPS|VBLENDVPD|VDPPS|VDPPD|VEXTRACTPS|VINSERTPS|VMOVNTDQA|VMPSADBW|VPACKUSDW|VPBLENDVB|VPBLENDW|VPCMEQQ|VPCMPGTQ|VPEXTRB|VPEXTRD|VPEXTRQ|VPINSRB|VPINSRD|VPINSRQ|VPMINSB|VPMINSD|VPMINUD|VPMINUW|VPMODEB|VPMOVSXBD|VPMOVSXBQ|VPMOVSXBW|VPMOVSXDQ|VPMOVSXWD|VPMOVSXWQ|VPMOVZXBD|VPMOVZXBQ|VPMOVZXBW|VPMOVZXDQ|VPMOVZXWD|VPMOVZXWQ|VPMULDQ|VPMULUDQ|VPCMPEQB|VPCMPEQD|VPCMPEQQ|VPCMPEQW|VPCMPGTB|VPCMPGTD|VPCMPGTW|VPMAXSB|VPMAXSD|VPMAXSW|VPMAXUB|VPMAXUD|VPMAXUW|VPMINSB|VPMINSD|VPMINSW|VPMINUB|VPMINUD|VPMINUW|VPMOVMSKB|VPMULHUW|VPMULHW|VPMULLW|VPMULLD|VPSADBW|VPSLLD|VPSLLDQ|VPSLLQ|VPSLLW|VPSRAD|VPSRAW|VPSRLD|VPSRLDQ|VPSRLQ|VPSRLW|VPSUBB|VPSUBD|VPSUBQ|VPSUBSB|VPSUBSW|VPSUBUSB|VPSUBUSW|VPSUBW|VPUNPCKHBW|VPUNPCKHDQ|VPUNPCKHQDQ|VPUNPCKHWD|VPUNPCKLBW|VPUNPCKLDQ|VPUNPCKLQDQ|VPUNPCKLWD|VSHUFPS|VSHUFPD|VANDPD|ANDPS|VANDNPD|VANDNPS|VORPD|VORPS|VXORPD|VXORPS|VRCPSS|VRSQRTSS|VFIXUPIMMSS|VRANGEPS|VRANGEPD|VRANGESS|VRANGESD|VREDUCEPS|VREDUCEPD|VREDUCESS|VREDUCESD|VGETEXPPS|VGETEXPPD|VGETEXPSS|VGETEXPSD|VGETMANTPS|VGETMANTPD|VGETMANTSS|VGETMANTSD|VSCALEFPS|VSCALEFPD|VSCALEFSS|VSCALEFSD|VEXP2PS|VEXP2PD|VRCP28PS|VRCP28PD|VRCP28SS|VRCP28SD|VRSQRT28PS|VRSQRT28PD|VRSQRT28SS|VRSQRT28SD|VGATHERPF0DPS|VGATHERPF0QPS|VGATHERPF0DPD|VGATHERPF0QPD|VGATHERPF1DPS|VGATHERPF1QPS|VGATHERPF1DPD|VGATHERPF1QPD|VSCATTERPF0DPS|VSCATTERPF0QPS|VSCATTERPF0DPD|VSCATTERPF0QPD|VSCATTERPF1DPS|VSCATTERPF1QPS|VSCATTERPF1DPD|VSCATTERPF1QPD|FPREM|FNCLEX|FNINIT|FNSAVE|FNSTCW|FNSTSW|FPATAN|FPREM|FPTAN|FRNDINT|FSCALE|FSETPM|FSIN|FSINCOS|FSQRT|FTST|FXAM|FXCH|FYL2X|FYL2XP1|SETO|SETNO|SETB|SETNB|SETC|SETNC|SETAE|SETNAE|SETE|SETNE|SETBE|SETNBE|SETA|SETNA|SETS|SETNS|SETP|SETNP|SETPE|SETPO|SETL|SETNL|SETGE|SETNGE|SETLE|SETNLE|CMOVO|CMOVNO|CMOVB|CMOVNB|CMOVC|CMOVNC|CMOVAE|CMOVNAE|CMOVE|CMOVNE|CMOVBE|CMOVNBE|CMOVA|CMOVNA|CMOVS|CMOVNS|CMOVP|CMOVNP|CMOVPE|CMOVPO|CMOVL|CMOVNL|CMOVGE|CMOVNGE|CMOVLE|CMOVNLE)(?![a-zA-Z0-9_.$])"
        }
      ]
    },
    "registers": {
      "name": "variable.language.nasm",
      "match": "(?<![a-zA-Z0-9_.$])(%[a-z]+\\s+)?(eax|ebx|ecx|edx|esi|edi|ebp|esp|eip|rax|rbx|rcx|rdx|rsi|rdi|rbp|rsp|rip|r8|r9|r10|r11|r12|r13|r14|r15|r8d|r9d|r10d|r11d|r12d|r13d|r14d|r15d|r8w|r9w|r10w|r11w|r12w|r13w|r14w|r15w|r8b|r9b|r10b|r11b|r12b|r13b|r14b|r15b|ax|bx|cx|dx|si|di|bp|sp|ah|al|bh|bl|ch|cl|dh|dl|spl|bpl|sil|dil|cr0|cr1|cr2|cr3|cr4|cr8|dr0|dr1|dr2|dr3|dr6|dr7|tr0|tr1|tr2|tr3|tr4|tr5|tr6|tr7|st0|st1|st2|st3|st4|st5|st6|st7|mm0|mm1|mm2|mm3|mm4|mm5|mm6|mm7|xmm0|xmm1|xmm2|xmm3|xmm4|xmm5|xmm6|xmm7|xmm8|xmm9|xmm10|xmm11|xmm12|xmm13|xmm14|xmm15|ymm0|ymm1|ymm2|ymm3|ymm4|ymm5|ymm6|ymm7|ymm8|ymm9|ymm10|ymm11|ymm12|ymm13|ymm14|ymm15|zmm0|zmm1|zmm2|zmm3|zmm4|zmm5|zmm6|zmm7|zmm8|zmm9|zmm10|zmm11|zmm12|zmm13|zmm14|zmm15|cs|ds|es|fs|gs|ss|fs.base|gs.base)(?![a-zA-Z0-9_.$])"
    },
    "sizeSpecifiers": {
      "name": "storage.type.nasm",
      "match": "\\b(byte|word|dword|qword|tword|oword|yword|zword|ptr|far|near)\\b"
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.nasm",
          "match": "(?<![a-zA-Z0-9_.$])(0[xX][0-9a-fA-F]+|[0-9]+[hH])(?![a-zA-Z0-9_.$])"
        },
        {
          "name": "constant.numeric.nasm",
          "match": "(?<![a-zA-Z0-9_.$])(0[oO][0-7]+|[0-7]+[oOqQ])(?![a-zA-Z0-9_.$])"
        },
        {
          "name": "constant.numeric.nasm",
          "match": "(?<![a-zA-Z0-9_.$])(0[bB][01]+|[01]+[bB])(?![a-zA-Z0-9_.$])"
        },
        {
          "name": "constant.numeric.nasm",
          "match": "(?<![a-zA-Z0-9_.$])([0-9]+[dD]|[0-9]+)(?![a-zA-Z0-9_.$])"
        },
        {
          "name": "constant.numeric.nasm",
          "match": "(?<![a-zA-Z0-9_.$])(\\$\\$|\\$)(?![a-zA-Z0-9_.$])"
        }
      ]
    },
    "operators": {
      "name": "keyword.operator.nasm",
      "match": "[+\\-*/%&|^~<>!]|<<|>>|//|&&|\\|\\||\\^\\^|==|!=|<=|>=|\\|\\||&&|\\^\\^|<<|>>|//|%%"
    },
    "brackets": {
      "patterns": [
        { "name": "punctuation.section.bracket.nasm", "match": "\\[" },
        { "name": "punctuation.section.bracket.nasm", "match": "\\]" },
        { "name": "punctuation.section.parens.nasm", "match": "\\(" },
        { "name": "punctuation.section.parens.nasm", "match": "\\)" }
      ]
    },
    "separators": {
      "name": "punctuation.separator.nasm",
      "match": ",|:"
    }
  }
}
